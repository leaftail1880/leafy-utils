{
  "name": "leafy-utils",
  "version": "7.1.6",
  "description": "Just some of my scripts",
  "main": "exports.js",
  "types": "types/exports.d.ts",
  "author": "leaftail1880",
  "license": "ISC",
  "type": "module",
  "scripts": {
    "build": "node ./build.js && tsc"
  },
  "bin": {
    "commit": "./bin/commit.js",
    "publish": "./bin/publish.js"
  },
  "files": [
    "src",
    "types",
    "exports.js",
    "install.js",
    "bin",
    "tsconfig.json"
  ],
  "exports": {
    ".": {
      "types": "./types/exports.d.ts",
      "default": "./exports.js"
    },
    "./src/**": {
      "types": "./types/**",
      "default": "./src/**"
    }
  },
  "prettier": {
    "semi": false,
    "arrowParens": "avoid",
    "singleQuote": true,
    "printWidth": 120
  },
  "devDependencies": {
    "@types/node": "^25.9.1"
  },
  "packageManager": "yarn@4.15.0+sha512.07ec708ac11e2eaa4ea2b04cfbb272812f7e74a753f1595eaef4486c663a98306a30cca3e6fc40f7a0b168dcfb3a2490b6a5e0501e20fb69cc36f563dd161c53",
  "dependencies": {
    "typescript": "^6.0.3"
  }
}
